# Environment variables for the AI Video Intelligence Platform
# Copy this file to .env and adjust the values for your environment.

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres@localhost:5432/videointel

# Redis connection string (broker + result backend for Celery)
REDIS_URL=redis://localhost:6379/0

# Directory paths (relative to the project root)
UPLOAD_DIR=uploads
PROCESSED_DIR=processed
ACTORS_DIR=actors

# Face recognition: minimum cosine similarity to accept a match (0–1)
FACE_THRESHOLD=0.45

# Object detection: minimum YOLO confidence score to accept a detection (0–1)
YOLO_CONFIDENCE=0.5

# Extract one frame every N seconds of video wall-clock time
FRAME_SAMPLE_INTERVAL=2

# Maximum frames sent to the face model in one batch
MAX_BATCH_SIZE=32
